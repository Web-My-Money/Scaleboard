# WMM Story Engine — environment configuration
# Copy to .env.local and fill in values

# Anthropic API key (required for AI features)
ANTHROPIC_API_KEY=

# Where client folders live on disk (default: ./data/clients)
WMM_DATA_DIR=./data/clients

# Storage backend: "fs" (local filesystem) or "supabase" (future)
STORAGE_DRIVER=fs

# AI provider: "anthropic" (direct) or "openrouter" (future)
AI_PROVIDER=anthropic
